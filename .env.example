# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── HERE API ────────────────────────────────────────────────────────────────
# Browser/public key (Maps JS SDK, used client-side)
NEXT_PUBLIC_HERE_API_KEY=your-here-browser-api-key
# Server-only key (Geocoding, Routing, Tour Planning)
HERE_API_KEY=your-here-server-api-key
HERE_SERVER_API_KEY=your-here-server-api-key   # alias, same value as HERE_API_KEY

# HERE OAuth (optional, for Tour Planning OAuth mode)
HERE_TOUR_PLANNING_AUTH=apikey                  # or "oauth"
HERE_ACCESS_KEY_ID=your-here-oauth-key-id
HERE_ACCESS_KEY_SECRET=your-here-oauth-key-secret

# ─── HERE Feature Flags ───────────────────────────────────────────────────────
HERE_TOUR_PLANNING_ENABLED=false                # set true to use paid Tour Planning API

# ─── HERE Cost Controls ───────────────────────────────────────────────────────
# Cost rates in cents per 1000 units (set from your HERE contract)
HERE_GEOCODING_COST_PER_1000_CENTS=50
HERE_ROUTING_COST_PER_1000_CENTS=100
HERE_TOUR_PLANNING_COST_PER_1000_CENTS=500
HERE_MAPS_JS_COST_PER_1000_CENTS=70

# Daily budget caps (in cents, 0 = no limit)
HERE_DAILY_BUDGET_CENTS=0
HERE_GEOCODING_DAILY_BUDGET_CENTS=0
HERE_ROUTING_DAILY_BUDGET_CENTS=0
HERE_TOUR_PLANNING_DAILY_BUDGET_CENTS=0

# Daily request limits (0 = no limit)
HERE_GEOCODING_DAILY_REQUEST_LIMIT=0
HERE_ROUTING_DAILY_REQUEST_LIMIT=0
HERE_TOUR_PLANNING_DAILY_REQUEST_LIMIT=0

# ─── HERE Geocoding Throttle ─────────────────────────────────────────────────
HERE_GEOCODING_BATCH_SIZE=5                     # max 10
HERE_GEOCODING_BATCH_DELAY_MS=1000
HERE_GEOCODING_REQUEST_DELAY_MS=250
HERE_GEOCODING_RETRIES=1                        # max 2
HERE_GEOCODING_PERSISTENT_CACHE=true            # set false to disable DB cache

# ─── HERE Routing Metrics ────────────────────────────────────────────────────
HERE_ROUTING_METRICS_ENABLED=false              # set true to use paid HERE Routing for metrics
ROUTE_METRICS_FALLBACK_SPEED_KMH=35

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Required for driver photo uploads (proof of delivery)
# 1. Go to Supabase Dashboard > Storage
# 2. Create a new bucket called "pod-media"
# 3. Set it to "Public" bucket
# 4. No additional env vars needed - uses your existing Supabase credentials

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
DELIVERY_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_ENABLE_POD_EMAIL=true

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SERVICE_TIME_PER_STOP_SEC=90
